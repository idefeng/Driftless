{
  "expo": {
    "name": "Driftless",
    "slug": "driftless",
    "version": "1.0.1",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "scheme": "driftless",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.idefeng.driftless",
      "infoPlist": {
        "UIBackgroundModes": [
          "audio"
        ],
        "NSSupportsLiveActivities": true
      }
    },
    "android": {
      "package": "com.idefeng.driftless",
      "adaptiveIcon": {
        "backgroundColor": "#F7F5F2",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "@bacons/apple-targets",
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash-icon.png",
          "resizeMode": "contain",
          "imageWidth": 280,
          "backgroundColor": "#F7F5F2",
          "dark": {
            "image": "./assets/splash-icon-dark.png",
            "backgroundColor": "#141109"
          }
        }
      ],
      "expo-localization"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "updates": {
      "url": "https://u.expo.dev/af22973b-c89f-4d59-b406-a2ae922cdc64",
      "checkAutomatically": "ON_LOAD",
      "fallbackToCacheTimeout": 0
    },
    "extra": {
      "router": {},
      "eas": {
        "build": {
          "experimental": {
            "ios": {
              "appExtensions": [
                {
                  "bundleIdentifier": "com.idefeng.driftless.widget",
                  "targetName": "DriftlessWidget"
                }
              ]
            }
          }
        },
        "projectId": "af22973b-c89f-4d59-b406-a2ae922cdc64"
      }
    },
    "owner": "idefeng"
  }
}
